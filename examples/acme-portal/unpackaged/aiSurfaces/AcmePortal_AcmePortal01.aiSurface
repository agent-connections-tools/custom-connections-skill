<?xml version="1.0" encoding="UTF-8"?>
<AiSurface xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Custom connection for the Acme Portal client application.</description>

    <instructions>
        <instruction>Always reply with brief, friendly responses. Keep messages under 200 characters when possible.</instruction>
        <sortOrder>1</sortOrder>
    </instructions>
    <instructions>
        <instruction>Do not use response formats where the response contains more than 7 choices.</instruction>
        <sortOrder>2</sortOrder>
    </instructions>
    <instructions>
        <instruction>Do not use any of the AcmePortal* response formats where the response contains only a single text-only choice without images or URLs.</instruction>
        <sortOrder>3</sortOrder>
    </instructions>

    <masterLabel>AcmePortal</masterLabel>

    <responseFormats>
        <enabled>true</enabled>
        <responseFormat>AcmePortalChoices_AcmePortal01</responseFormat>
    </responseFormats>
    <responseFormats>
        <enabled>true</enabled>
        <responseFormat>AcmePortalChoicesWithImages_AcmePortal01</responseFormat>
    </responseFormats>
    <responseFormats>
        <enabled>true</enabled>
        <responseFormat>AcmePortalTimePicker_AcmePortal01</responseFormat>
    </responseFormats>

    <surfaceType>Custom</surfaceType>
</AiSurface>
